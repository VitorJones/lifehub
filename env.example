# ─── Desenvolvimento local ────────────────────────────────────────────────────
# Não precisa de nada — o app usa SQLite local automaticamente (prisma/dev.db)
# O DATABASE_URL abaixo já está no .env gerado pelo Prisma

DATABASE_URL="file:./dev.db"

# ─── Produção (Vercel) ────────────────────────────────────────────────────────
# Adicione estas duas variáveis no painel da Vercel:
# Settings → Environment Variables

TURSO_DATABASE_URL=libsql://lifeforge-SEU_USUARIO.turso.io
TURSO_AUTH_TOKEN=eyJ...token_gerado_pelo_turso...

# ─── Autenticação (NextAuth v5) ───────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=sua_chave_secreta_aqui
